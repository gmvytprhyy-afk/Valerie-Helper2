# ─── Required ───────────────────────────────────────────────────────────
# Your Discord bot token (from https://discord.com/developers/applications)
DISCORD_TOKEN=your_bot_token_here

# PostgreSQL connection string
# Railway example: postgresql://postgres:password@containers-us-west-xxx.railway.app:5432/railway
DATABASE_URL=postgresql://user:password@localhost:5432/valerie_helper

# ─── Optional (used by deploy.ts only) ──────────────────────────────────
# Set your bot's client ID in config.json, not here.
# Use: npm run deploy           — register commands to the dev guild (fast)
# Use: npm run deploy -- --global — register commands globally (takes ~1 hour to propagate)
